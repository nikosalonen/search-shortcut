{
  "manifest_version": 3,
  "name": "Search Focus",
  "version": "1.0.0",
  "description": "Focus on search input with keyboard shortcut",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["index.js"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "search-shortcut@nikosalonen",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
